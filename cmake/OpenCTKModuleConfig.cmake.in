@PACKAGE_INIT@

cmake_minimum_required(VERSION @min_new_policy_version@...@max_new_policy_version@)

# Helper functions required by install-tree Config files (normally defined in build-time cmake modules).
# QExt pattern: these must be inlined because build-time cmake modules are NOT installed.
if(NOT COMMAND __octk_internal_promote_target_to_global)
    function(__octk_internal_promote_target_to_global target)
        get_property(_is_global TARGET ${target} PROPERTY IMPORTED_GLOBAL)
        if(NOT _is_global)
            message(DEBUG "Promoting target to global: '${target}'")
            set_property(TARGET ${target} PROPERTY IMPORTED_GLOBAL TRUE)
        endif()
    endfunction()
endif()
if(NOT COMMAND __octk_internal_promote_target_to_global_checked)
    function(__octk_internal_promote_target_to_global_checked target)
        if(OCTK_PROMOTE_TO_GLOBAL_TARGETS AND CMAKE_VERSION VERSION_LESS 3.21)
            __octk_internal_promote_target_to_global(${target})
        endif()
    endfunction()
endif()
if(NOT COMMAND _octk_internal_suggest_dependency_debugging)
    function(_octk_internal_suggest_dependency_debugging dep_target var_name)
    endfunction()
endif()
if(NOT COMMAND octk_make_features_available)
    function(octk_make_features_available target)
    endfunction()
endif()
if(NOT COMMAND _octk_internal_find_third_party_dependencies)
    function(_octk_internal_find_third_party_dependencies dep_target deps_var)
    endfunction()
endif()
if(NOT COMMAND _octk_internal_find_tool_dependencies)
    function(_octk_internal_find_tool_dependencies dep_target deps_var)
    endfunction()
endif()
if(NOT COMMAND _octk_internal_find_octk_dependencies)
    function(_octk_internal_find_octk_dependencies dep_target deps_var paths_var)
        set(_deps "${${deps_var}}")
        if(NOT _deps)
            return()
        endif()
        set(_paths "${${paths_var}}")
        foreach(_dep_entry IN LISTS _deps)
            string(REPLACE "\\;" ";" _dep_parts "${_dep_entry}")
            list(GET _dep_parts 0 _dep_pkg)
            list(GET _dep_parts 1 _dep_ver)
            find_dependency(${_dep_pkg} ${_dep_ver}
                PATHS ${_paths}
                ${__octk_use_no_default_path_for_octk_packages}
            )
        endforeach()
    endfunction()
endif()

include(CMakeFindDependencyMacro)

# Create stub targets for OpenCTK 3rdparty libraries referenced by
# installed INTERFACE_LINK_LIBRARIES. Auto-generated at build time.
@octk_3rdparty_stubs@

get_filename_component(_import_prefix "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(_import_prefix "${_import_prefix}" REALPATH)

# Extra cmake code begin
@extra_cmake_code@
# Extra cmake code end

# Find required dependencies, if any.
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Dependencies.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Dependencies.cmake")
    _octk_internal_suggest_dependency_debugging(@name@
        __octk_@name@_pkg ${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE)
endif()

# If *ConfigDependencies.cmake exists, the variable value will be defined there.
# Don't override it in that case.
if(NOT DEFINED "OpenCTK@name@_FOUND")
    set("OpenCTK@name@_FOUND" TRUE)
endif()

if (NOT OCTK_NO_CREATE_TARGETS AND OpenCTK@name@_FOUND)
    include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Targets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@AdditionalTargetInfo.cmake")
    if(NOT OCTK_NO_CREATE_VERSIONLESS_TARGETS)
        include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@VersionlessTargets.cmake")
    endif()

    # DEPRECATED
    # Provide old style variables for includes, compile definitions, etc.
    # These variables are deprecated and only provided on a best-effort basis to facilitate porting.
    # Consider using target_link_libraries(app PRIVATE @OCTK_CMAKE_EXPORT_NAMESPACE@@name@) instead.
    set(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_LIBRARIES "@OCTK_CMAKE_EXPORT_NAMESPACE@::@name@")

    get_target_property(_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_INCLUDE_DIRS
                        @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@ INTERFACE_INCLUDE_DIRECTORIES)
    if(NOT _@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_INCLUDE_DIRS)
        set(_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_INCLUDE_DIRS "")
    endif()

    if(TARGET @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@_private)
        get_target_property(_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_PRIVATE_INCLUDE_DIRS
                            @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@_private INTERFACE_INCLUDE_DIRECTORIES)
        if(NOT _@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_PRIVATE_INCLUDE_DIRS)
            set(_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_PRIVATE_INCLUDE_DIRS "")
        endif()
    endif()

    get_target_property(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS
                        @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@ INTERFACE_COMPILE_DEFINITIONS)
    if(NOT @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS)
        set(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS "")
    else()
        list(TRANSFORM @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS PREPEND "-D")
    endif()

    get_target_property(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_COMPILE_DEFINITIONS
                        @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@ INTERFACE_COMPILE_DEFINITIONS)
    if(NOT @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_COMPILE_DEFINITIONS)
        set(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_COMPILE_DEFINITIONS "")
    endif()

    set(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_INCLUDE_DIRS
        ${_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_INCLUDE_DIRS})

    set(@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_PRIVATE_INCLUDE_DIRS
        ${_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_OWN_PRIVATE_INCLUDE_DIRS})

    foreach(_module_dep ${_@OCTK_CMAKE_EXPORT_NAMESPACE@@name@_MODULE_DEPENDENCIES})
        list(APPEND @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_INCLUDE_DIRS
             ${@OCTK_CMAKE_EXPORT_NAMESPACE@${_module_dep}_INCLUDE_DIRS})
        list(APPEND @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_PRIVATE_INCLUDE_DIRS
             ${@OCTK_CMAKE_EXPORT_NAMESPACE@${_module_dep}_PRIVATE_INCLUDE_DIRS})
        list(APPEND @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS
             ${@OCTK_CMAKE_EXPORT_NAMESPACE@${_module_dep}_DEFINITIONS})
        list(APPEND @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_COMPILE_DEFINITIONS
             ${@OCTK_CMAKE_EXPORT_NAMESPACE@${_module_dep}_COMPILE_DEFINITIONS})
    endforeach()

    list(REMOVE_DUPLICATES @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_INCLUDE_DIRS)
    list(REMOVE_DUPLICATES @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_PRIVATE_INCLUDE_DIRS)
    list(REMOVE_DUPLICATES @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_DEFINITIONS)
    list(REMOVE_DUPLICATES @OCTK_CMAKE_EXPORT_NAMESPACE@@name@_COMPILE_DEFINITIONS)
endif()

if (TARGET @OCTK_CMAKE_EXPORT_NAMESPACE@::@name@)
    foreach(extra_cmake_include @extra_cmake_includes@)
        include("${CMAKE_CURRENT_LIST_DIR}/${extra_cmake_include}")
    endforeach()

    octk_make_features_available(@OCTK_CMAKE_EXPORT_NAMESPACE@::@name@)

    if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Plugins.cmake")
        include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Plugins.cmake")
    endif()

    list(APPEND OCTK_ALL_LIBRARIES_FOUND_VIA_FIND_PACKAGE "@name@")

    get_target_property(_octk_library_target_type "OpenCTK::@name@" TYPE)
    if(NOT _octk_library_target_type STREQUAL "INTERFACE_LIBRARY")
        get_target_property(_octk_library_plugin_types
                            OpenCTK::@name@ LIBRARY_PLUGIN_TYPES)
        if(_octk_library_plugin_types)
            list(APPEND OCTK_ALL_PLUGIN_TYPES_FOUND_VIA_FIND_PACKAGE "${_octk_library_plugin_types}")
        endif()
    endif()


    # Load Module's BuildInternals should any exist
    if (OpenCTKBuildInternals_DIR AND
        EXISTS "${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@BuildInternals.cmake")
        include("${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@BuildInternals.cmake")
    endif()
else()

    set(OpenCTK@name@_FOUND FALSE)
    if(NOT DEFINED OpenCTK@name@_NOT_FOUND_MESSAGE)
        set(OpenCTK@name@_NOT_FOUND_MESSAGE
            "Target \"@OCTK_CMAKE_EXPORT_NAMESPACE@::@name@\" was not found.")

        if(OCTK_NO_CREATE_TARGETS)
            string(APPEND OpenCTK@name@_NOT_FOUND_MESSAGE
                "Possibly due to OCTK_NO_CREATE_TARGETS being set to TRUE and thus "
                "${CMAKE_CURRENT_LIST_DIR}/OpenCTK@name@Targets.cmake was not "
                "included to define the target.")
        endif()
    endif()
endif()
